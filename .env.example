# App URL
# This is your own app's public URL.
# Local development: usually http://localhost:3000
# Production: use the live domain where this app is deployed.
APP_BASE_URL=http://localhost:3000

# MongoDB database connection
# Get this from your MongoDB provider dashboard.
# Common sources:
# MongoDB Atlas: Database > Connect > Drivers
# Local MongoDB: usually mongodb://127.0.0.1:27017
# Example Atlas format:
# mongodb+srv://username:password@cluster-name.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://username:password@127.0.0.1:27017/?authSource=admin

# MongoDB database name
# You choose this name yourself when using MongoDB.
# Example: auto-payment-reminder
MONGODB_DB=auto-payment-reminder

# MongoDB collection name
# Optional. This app stores its main application state in one collection document.
MONGODB_COLLECTION=app_state

# Cron protection secret
# Create this yourself as a random long string.
# Use the same value in the `x-cron-secret` header, or as `Authorization: Bearer <secret>`
# when calling POST /api/cron/run from a scheduler like Vercel Cron, GitHub Actions, or any server job.
CRON_SECRET=your-cron-secret-goes-here

# Dispatch fallback settings
# The dashboard settings are still the primary source.
# These env vars are only used as fallback values if the dashboard fields are left empty.

# Safe testing mode
# `true` means reminders are generated but not actually sent to email/SMS/WhatsApp providers.
# Set this to `false` only after real provider credentials are configured.
REMINDER_SIMULATE_MODE=true

# SMTP email provider settings
# Get these from your email sending provider or mail server admin.
# Common sources: Gmail SMTP, Zoho Mail, Outlook 365, SendGrid SMTP, Mailgun SMTP, Amazon SES SMTP.
# Example host values:
# Gmail: smtp.gmail.com
# Outlook: smtp.office365.com
# Zoho: smtp.zoho.in or smtp.zoho.com
SMTP_HOST=smtp.example.com

# SMTP port from your email provider docs.
# Common values:
# 587 for TLS/STARTTLS
# 465 for SSL
SMTP_PORT=587

# `true` usually goes with port 465.
# `false` usually goes with port 587.
SMTP_SECURE=false

# SMTP login username from your email provider.
# Often this is the full email address of the sending inbox.
SMTP_USER=you@example.com

# SMTP password from your email provider.
# This may be the mailbox password or an app password/API-generated SMTP password.
SMTP_PASS=your-smtp-password

# The email address that should appear in the "From" field when reminders are sent.
# Usually this must be an address verified with your email provider.
SMTP_FROM=you@example.com

# Twilio SMS settings
# You can find these in the Twilio Console.
# Twilio docs: https://www.twilio.com/docs/messaging/api
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Twilio phone number used as the SMS sender.
# Must be a Twilio number in E.164 format.
TWILIO_FROM_NUMBER=+XXXXXXXXXXX

# Twilio WhatsApp sender number.
# Use the approved WhatsApp-enabled Twilio sender or sandbox number in E.164 format.
# The app will send it to Twilio as `whatsapp:+<number>` automatically.
TWILIO_WHATSAPP_FROM_NUMBER=+XXXXXXXXXXX
